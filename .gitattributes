# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Shell scripts
*.sh text eol=lf
startup.txt text eol=lf

# Text files
*.txt text eol=lf
*.md text eol=lf
README.md text eol=lf
DEPLOY.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.pptx binary
*.xlsx binary
*.ppt binary
*.xls binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
